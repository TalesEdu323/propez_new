# ==============================================================================
# PropEZ — Variáveis de ambiente
# ==============================================================================
# Copie este arquivo para `.env` (nunca commitar) e ajuste os valores marcados
# com <PREENCHER>. Tudo que está com valor já documentado aqui é um default
# seguro ou um ID real (Stripe) que pode subir sem mudança.
# ==============================================================================


# ------------------------------------------------------------------------------
# 1) Infraestrutura básica
# ------------------------------------------------------------------------------

# URL pública do app (usada para success/cancel do Stripe e CORS).
# Em dev: http://localhost:3000
# Em prod: https://app.propez.com  (ou seu Cloud Run / Vercel)
APP_URL=https://<PREENCHER>.run.app

# Porta do servidor Express (default 3000).
PORT=3000

# Origens extras permitidas no CORS (separadas por vírgula, sem espaços).
# O próprio APP_URL e localhost já são liberados automaticamente; inclua aqui
# apenas domínios adicionais (ex.: staging, domínio de marca, etc.).
CORS_ORIGINS=http://localhost:3000

# NODE_ENV controla o modo de bundle (Vite dev vs. dist estático).
# Em prod, defina como `production` na plataforma (Cloud Run, etc.).
# NODE_ENV=production


# ------------------------------------------------------------------------------
# 2) Banco de dados (Neon / Postgres)
# ------------------------------------------------------------------------------
# String de conexão Postgres com SSL. Usado para persistir integrações
# (ProSync/Rubrica) e dados server-side.
DATABASE_URL=postgres://<user>:<password>@<host>/<dbname>?sslmode=require


# ------------------------------------------------------------------------------
# 3) Stripe — pagamento e assinaturas
# ------------------------------------------------------------------------------

# Chave secreta do Stripe (painel > Developers > API keys).
#   - `sk_test_...` para sandbox
#   - `sk_live_...` para produção
STRIPE_SECRET_KEY=sk_live_<PREENCHER>

# Secret do webhook (painel > Developers > Webhooks > endpoint).
# Endpoint a configurar no painel: {APP_URL}/api/stripe/webhook
# Eventos mínimos a escutar:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_succeeded
#   invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_<PREENCHER>

# Price IDs dos planos (já criados em live mode via MCP).
# Se criar novos em outra conta/ambiente, substitua pelos IDs correspondentes.
#
# Plano Pro     — R$ 89/mês   ou  R$ 828/ano   (2 meses grátis → R$ 69/mês)
STRIPE_PRICE_PRO_MONTHLY=price_1TOKJpJpoS0DWavr1GJcEKVh
STRIPE_PRICE_PRO_YEARLY=price_1TOKJpJpoS0DWavrd4xBru73
#
# Plano Business — R$ 249/mês  ou  R$ 2.388/ano (2 meses grátis → R$ 199/mês)
STRIPE_PRICE_BUSINESS_MONTHLY=price_1TOKJqJpoS0DWavrRKbFZMjQ
STRIPE_PRICE_BUSINESS_YEARLY=price_1TOKJrJpoS0DWavrX2FfABC3


# ------------------------------------------------------------------------------
# 4) ProSync (CRM) — integração opcional
# ------------------------------------------------------------------------------
# Usado pelo plano Pro/Business para sincronizar clientes e propostas.
# Deixe em branco se não for usar ProSync — o app continua funcionando.
PROSYNC_API_URL=https://app.prosync.com.br
PROSYNC_API_KEY=ps_live_<PREENCHER>

# Secret usado para validar HMAC de webhooks recebidos do ProSync.
# Gere um valor aleatório forte (ex.: `openssl rand -hex 32`) e cadastre o mesmo
# no painel ProSync ao configurar o webhook de volta.
PROSYNC_WEBHOOK_SECRET=<PREENCHER_random_32_bytes_hex>


# ------------------------------------------------------------------------------
# 5) Rubrica (assinatura eletrônica) — integração opcional
# ------------------------------------------------------------------------------
# Usado pelo plano Pro/Business para enviar contratos para assinatura digital.
# Deixe em branco se não for usar Rubrica.
RUBRICA_API_URL=https://app.rubrica.com.br
RUBRICA_API_KEY=dm_live_<PREENCHER>

# Secret passado em query string ao Rubrica para autenticar os webhooks de volta.
# Gere um valor aleatório forte (`openssl rand -hex 32`).
RUBRICA_WEBHOOK_SECRET=<PREENCHER_random_32_bytes_hex>


# ==============================================================================
# Checklist de deploy
# ==============================================================================
# [ ] APP_URL apontando para o domínio real (sem barra no final)
# [ ] DATABASE_URL com sslmode=require
# [ ] STRIPE_SECRET_KEY em modo live
# [ ] Webhook cadastrado no Stripe apontando para {APP_URL}/api/stripe/webhook
#     e STRIPE_WEBHOOK_SECRET copiado do painel
# [ ] Todos os 4 STRIPE_PRICE_* preenchidos
# [ ] NODE_ENV=production definido na plataforma (Cloud Run, Vercel, etc.)
# [ ] CORS_ORIGINS incluindo qualquer domínio alternativo (ex.: www. + apex)
# [ ] ProSync: script CREATE_API_KEYS_AND_WEBHOOKS.sql aplicado no DB do ProSync
# [ ] ProSync: PROSYNC_API_KEY + PROSYNC_WEBHOOK_SECRET (igual ao secret do webhook outbound)
# [ ] Rubrica: RUBRICA_API_KEY (webhook de volta usa secret por URL; ver docs/INTEGRACOES_SMOKE_TEST.md)
# [ ] Boot PropEZ: log "[startup] integration schema OK" e npm run check:integrations com dev rodando
# ==============================================================================
